# Latest Updates / Social Feed configuration
# Copy this file to .env for local sync runs. In GitHub Actions, add these as repository secrets.

SOCIAL_UPDATES_LIMIT=6
SOCIAL_INCLUDE_REPOSTS=false
SOCIAL_GRAPH_API_VERSION=v20.0
SOCIAL_FALLBACK_IMAGE=/images/img1.jpeg

# Facebook Page Graph API
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# Instagram Graph API requires a Business/Creator Instagram account connected to a Facebook Page.
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# LinkedIn Organization API
LINKEDIN_ORGANIZATION_ID=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_API_VERSION=202405

# X API v2
X_USERNAME=
X_BEARER_TOKEN=

# YouTube channel feed
YOUTUBE_CHANNEL_ID=
